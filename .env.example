# Set AWS_PROFILE and AWS_REGION as env vars if needed
BEDROCK_MODEL_ID=eu.anthropic.claude-sonnet-4-6
LOG_LEVEL=INFO

# Memory (set to true + provide IDs after terraform apply)
MEMORY_ENABLED=false
MEMORY_ID=
MEMORY_SUMMARIZATION_STRATEGY_ID=

# Remote CLI (set after terraform apply: terraform output -raw runtime_arn)
AGENTCORE_RUNTIME_ARN=
